<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:San11PVPToolClient.Dialogs"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        x:Class="San11PVPToolClient.Dialogs.TextBoxDialog"
        x:DataType="local:TextBoxDialogViewModel"
        Icon="/Assets/pvpTool.ico"
        Title="TextBoxDialog">
  <StackPanel Margin="30,10">
    <TextBlock Text="{Binding Message}"
               Margin="10" />

    <TextBox Name="TextBox" Text="{Binding Text}"
             PasswordChar="{Binding PasswordChar}" RevealPassword="{Binding !IsPassword}"
             Width="200" Margin="10" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
      <Button Content="确认" IsDefault="True" Click="ButtonConfirm_Click" Margin="10" />
      <Button Content="取消" IsCancel="True" Click="ButtonClose_Click" Margin="10" />
    </StackPanel>
  </StackPanel>
</Window>
